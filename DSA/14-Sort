template <class type>
class Sort {
    public:
        Sort() {}
        void bubbleSort(type*, int);
        void countSort(type*, int);
        void descending(type*, int);
        void insertionSort(type*, int);
        void heapSort(type*, int);
        void mergeSort(type*, int);
        void quickSort(type*, int, int);
        void radixSort(type*, int);
        void selectionSort(type*, int);
        void shellSort(type*, int);
};

template <class type>
void Sort<type>::bubbleSort(type *array, int size) {
    bool flag;
    size--;

    for (int i = 0; i < size; i++) {
        flag = false;

        for (int j = 0; j < size - i; j++) {
            if (array[j] > array[j+1]) {
                swap(array[j], array[j+1]);
            }
            flag = true;
        }
        if (not flag) {
            return;
        }
    }
}
template <class type>
void Sort<type>::countSort(type *array, int size) {
    int max = array[0], i, j;

    for (i = 1; i < size; i++) {
        if (array[i] > max) {
            max = array[i];
        }
    }
    int *list = new type[++max];

    for (i = 0; i < max; i++) {
        list[i] = 0;
    }
    for (i = 0; i < size; i++) {
        list[array[i]]++;
    }
    i = j = 0;

    while (i < max) {
        if (list[i] > 0) {
            array[j++] = i;
            list[i]--;
        } else {
            i++;
        }
    }
}
template <class type>
void Sort<type>::descending(type *array, int size) {
    for (int i = 0; i < size/2; i++) {
        swap(array)
    }
}
template <class type>
void Sort<type>::insertionSort(type *array, int size) {
    type temp;

    for (int i = 1, j; i < size; i++) {
        temp = array[i];
        j = i - 1;

        while (j > -1 && array[j] > temp) {
            array[j+1] = array[j];
            j--;
        }
        array[j+1] = temp;
    }
}
template <class type>
void Sort<type>::heapSort(type *array, int size) {
    Heap<type> heap(array, size, "min");

    for (int i = 0; i < size; i++) {
        array[i] = heap.remove();
    }
}
template <class type>
void Sort<type>::mergeSort(type *array, int size) {
    auto merge = [](type *array, int low, int mid, int high) -> void {
        type *list = new type[high + 1];
        int i = low, j = mid  + 1, k = low;

        while (i <= mid && j <= high) {
            if (array[i] < array[j]) {
                list[k++] = array[i++];
            } else if (array[i] > array[j) {
                list[k++] = array[j++];
            } else {
                list[k++] = array[i++];
                list[k++] = array[j++];
            }
        }
        for (; i <= mid; i++) {
            list[k++] = array[i++];
        }
        for (; j <= high; j++) {
            list[k++] = array[j++];
        }
        for (i = low; i <= high; i++) {
            array[i] = list[i];
        }
    };
    int k = 2, low, mid, high;

    for (; k <= size; k *= 2) {
        for (int i = 0; i + k - 1 < size; i += k) {
            low = i;
            high = i + k - 1;
            mid = (low + high) / 2;
            merge(array, low, mid, high);
        }
    }
    if (k / 2 < size) {
        merge(array, 0, k / 2, size - 1);
    }
}
template <class type>
void Sort<type>::quickSort(type *array, int low, int high) {
    auto partition = [](type *array, int low, int high) -> int {
        int pivot = array[low], i = low, j = high;

        do {
            do {
                i++;
            } while (array[i] <= pivot);
            do {
                j--;
            } while (array[j] > pivot);
            if (i < j) {
                swap(array[i], array[j]);
            }
        } while (i < j);
        swap(array[low], array[j]);
        return j;
    };
    if (low < high) {
        int temp = partition(array, low, high);
        this->quickSort(array, low, temp-1);
        this->quickSort(array, temp+1, high); 
    }
}
template <class type>
void Sort<type>::radixSort(type *array, int size) {
    struct Node {
        type data = 0;
        Node *next = nullptr;
        Node(type data) {this->data = data;}
    };
    Node **list = new Node*[10], *current;
    int max = array[0], i, j, div;

    for (i = 1; i < size; i++) {
        if (array[i] > max) {
            max = array[i];
        }
    }
    for (int k = 1; k <= max; k *= 10) {
        for (i = 0; i < 10; i++) {
            list[i] = nullptr;
        }
        for (i = 0; i < size; i++) {
            div = (array[i] / k) % 10;

            if (not list[div]) {
                list[div] = new Node(array[i]);
            } else {
                current = list[div];

                while (current->next) {
                    current = current->next;
                }
                current->next = new Node(array[i]);
            }
        }
        for (i = j = 0; i < 10; i++) {
            current = list[i];

            while (current) {
                array[j++] = current->data;
                current = current->next;
            }
        }
    }
}
template <class type>
void Sort<type>::selectionSort(type *array, int size) {
    int i, j, k;

    for (i = 0; i < size - 1; i++) {
        for (j = i + 1, k = i; j < size; j++) {
            if (array[j] < array[k]) {
                k = j;
            }
        }
        swap(array[i], array[k]);
    }
}
template <class type>
void Sort<type>::shellSort(type *array, int size) {
    type temp;

    for (int gap = size / 2, i, j; gap >= 1; gap /= 2) {
        for (i = gap; i < size; i++) {
            temp = array[i];
            j = i - gap;

            while (j > -1 && array[j] > temp) {
                array[j+gap] = array[j];
                j -= gap;
            }
            array[j+gap] = temp;
        }
    }
}

void print(int *array, int size) {
    if (not size) {
        cout << "No elements to display" << endl;
    } else {
        cout << '[';
        size--;
        for (int i = 0; i < size; i++) cout << array[i] << ", ";
        cout << array[size] <<  ']' << endl;
    }
}